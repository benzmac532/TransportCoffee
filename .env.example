# Shopify Storefront API
# Create a custom app in Shopify Admin → Settings → Apps and sales channels → Develop apps
# Enable Storefront API with product/collection/cart scopes, then install the app.
#
# VITE_SHOPIFY_STORE_DOMAIN should be your *.myshopify.com host (not the custom domain).
# Example: transportcoffeeroasters.myshopify.com
VITE_SHOPIFY_STORE_DOMAIN=
VITE_SHOPIFY_STOREFRONT_TOKEN=

# Optional: public storefront URL used as a read-only fallback for product JSON
# when the Storefront token is not configured yet.
VITE_SHOPIFY_PUBLIC_URL=https://transportcoffeeroasters.com
